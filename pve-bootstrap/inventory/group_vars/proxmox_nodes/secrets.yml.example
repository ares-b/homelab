---
# The live file is secrets.sops.yml: SOPS-encrypted (committed) and decrypted
# automatically by the community.sops vars plugin (see ansible.cfg).
#
# To create it: fill this in, then either
#   cp secrets.yml.example secrets.sops.yml && sops -e -i secrets.sops.yml
# or run `make pve-init` (init.yml generates the keypair + tf password and
# writes secrets.sops.yml encrypted for you).
#
# A plaintext secrets.yml is gitignored and must never be committed.

# ansible automation account SSH key (machine identity, not a human).
pve_ansible_ssh_pub_key: "ssh-ed25519 AAAA... ansible@pve01"
pve_ansible_ssh_private_key_b64: "<base64 of the matching OpenSSH private key>"

# PVE realm / Linux passwords.
pve_secret_password_ares: "CHANGE_ME"
pve_secret_password_terraform: "CHANGE_ME"
pve_secret_password_packer: "CHANGE_ME"
pve_secret_token_terraform: ""

# Notification SMTP relay (optional; leave blank to skip).
pve_notifications_smtp_host: ""
pve_notifications_smtp_port: 587
pve_notifications_smtp_user: ""
pve_notifications_smtp_password: ""
