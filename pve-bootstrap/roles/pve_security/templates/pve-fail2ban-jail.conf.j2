[DEFAULT]
ignoreip = {{ pve_security_fail2ban_ignoreips | join(' ') }}

# Proxmox Web UI brute-force protection
[proxmox]
enabled   = true
port      = https,8006
filter    = proxmox
logpath   = /var/log/pveproxy/access.log
maxretry  = {{ pve_security_fail2ban_maxretry }}
bantime   = {{ pve_security_fail2ban_bantime }}
findtime  = {{ pve_security_fail2ban_findtime }}
action    = iptables-multiport[name=proxmox, port="8006,443", protocol=tcp]

# SSH brute-force protection
[sshd]
enabled   = true
port      = {{ pve_common_ssh_port | default(22) }}
filter    = sshd
logpath   = /var/log/auth.log
maxretry  = {{ pve_security_fail2ban_maxretry }}
bantime   = {{ pve_security_fail2ban_bantime }}
findtime  = {{ pve_security_fail2ban_findtime }}
