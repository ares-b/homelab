#!/bin/sh
# Recover the WireGuard tunnel when the VPS peer becomes unreachable.
# The LXC gateway dials the VPS through double-NAT; a WAN IP change or a
# dropped UDP mapping can leave the peer's endpoint stale until a fresh
# handshake. Restarting wg-quick forces re-registration.
set -eu

peer="{{ wireguard.vps_ip }}"
iface="wg0"

for _ in 1 2 3; do
    if ping -c1 -W5 "$peer" >/dev/null 2>&1; then
        exit 0
    fi
    sleep 2
done

logger -t wg-watchdog "peer $peer unreachable, restarting wg-quick@$iface"
systemctl restart "wg-quick@$iface"
