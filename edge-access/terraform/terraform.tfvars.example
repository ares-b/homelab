# Not used when running via `make tf-apply` (config.sops.yaml is the source).
# Only needed for direct `terraform` CLI invocations without SOPS.

proxmox = {
  endpoint        = "https://REDACTED_PVE_IP:8006/"
  api_token       = "terraform@pve!edge-token=REPLACE"
  insecure        = true
  node            = "pve01"
  node_address    = "REDACTED_PVE_IP"
  ssh_username    = "ansible"
  ssh_private_key = <<-EOT
    -----BEGIN OPENSSH PRIVATE KEY-----
    REPLACE
    -----END OPENSSH PRIVATE KEY-----
  EOT
}

lxc = {
  vmid                    = 200
  hostname                = "edge-gateway"
  cpus                    = 1
  memory                  = 512
  disk_size               = 4
  storage                 = "local-lvm"
  bridge                  = "vmbr0"
  ip                      = "192.168.0.200/24"
  gateway                 = "192.168.0.1"
  ssh_public_key          = "ssh-ed25519 AAAA... ansible@edge-gateway"
  ansible_ssh_private_key = "REPLACE"
}
